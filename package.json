{
  "name": "nostr-passkey",
  "version": "0.1.1",
  "description": "Nostr authentication and key management using WebAuthn Passkeys PRF extension",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./applesauce": {
      "types": "./dist/applesauce.d.ts",
      "import": "./dist/applesauce.js",
      "default": "./dist/applesauce.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nostr",
    "passkey",
    "webauthn",
    "prf",
    "cryptography",
    "security"
  ],
  "author": "imattau",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imattau/nostr-passkey.git"
  },
  "bugs": {
    "url": "https://github.com/imattau/nostr-passkey/issues"
  },
  "homepage": "https://github.com/imattau/nostr-passkey#readme",
  "peerDependencies": {
    "applesauce-accounts": "^6.2.0",
    "applesauce-signers": "^6.2.0",
    "nostr-tools": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "applesauce-accounts": {
      "optional": true
    },
    "applesauce-signers": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "applesauce-accounts": "^6.2.0",
    "applesauce-signers": "^6.2.0",
    "nostr-tools": "^2.23.8",
    "tsup": "^8.1.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
